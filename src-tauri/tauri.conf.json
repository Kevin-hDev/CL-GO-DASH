{
  "$schema": "https://raw.githubusercontent.com/nicholasVilela/tauri-rs/refs/heads/master/crates/tauri-utils/schema.json",
  "productName": "CL-GO",
  "version": "0.6.1",
  "identifier": "com.clgo.dash",
  "build": {
    "beforeDevCommand": "[ -f src-tauri/resources/ollama-bundle/ollama ] || (cd src-tauri && bash scripts/download-ollama.sh); npm run dev",
    "beforeBuildCommand": "[ -f src-tauri/resources/ollama-bundle/ollama ] || (cd src-tauri && bash scripts/download-ollama.sh); npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CL-GO",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 24 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/ollama-bundle/**/*"
    ]
  }
}

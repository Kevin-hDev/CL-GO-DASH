{
  "$schema": "https://raw.githubusercontent.com/nicholasVilela/tauri-rs/refs/heads/master/crates/tauri-utils/schema.json",
  "productName": "CL-GO",
  "version": "0.9.7",
  "identifier": "com.clgo.dash",
  "build": {
    "beforeDevCommand": "node scripts/cef/prepare-cef-source.mjs && npm run dev",
    "beforeBuildCommand": "node scripts/cef/prepare-cef-source.mjs && npm run build && cd src-tauri && bash scripts/prepare-searxng.sh && bash scripts/prepare-cef.sh",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CL-GO",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 18 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "default-skills/**/*",
      "resources/forecast-sidecar/**/*",
      "resources/searxng-sidecar/**/*"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "frameworks": [
        "target/cef-runtime/macos/Chromium Embedded Framework.framework"
      ],
      "files": {
        "Frameworks": "target/cef-runtime/macos/helpers",
        "Resources/cef/LICENSE.txt": "target/cef-runtime/macos/LICENSE.txt"
      }
    }
  }
}
